generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  PRESTATAIRE
  ADMIN
}

enum StatutReservation {
  EN_ATTENTE
  CONFIRMEE
  ANNULEE
  TERMINEE
}

enum PackPremium {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
}

enum StatutAbonnement {
  EN_ATTENTE
  ACTIF
  EXPIRE
  REFUSE
}

enum MoyenPaiement {
  WAVE
  ORANGE_MONEY
  MTN
  ESPECES
}

model User {
  id           String        @id @default(cuid())
  nom          String
  prenom       String
  email        String        @unique
  motDePasse   String
  telephone    String?
  role         Role          @default(CLIENT)
  avatar       String?
  estPremium   Boolean       @default(false)
  premiumJusquau DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  prestataire  Prestataire?
  reservations Reservation[]
  avis         Avis[]
  actif        Boolean       @default(true)
  tokenVersion Int @default(0)
  favoris      Favori[]
  notifications Notification[]
  abonnements  Abonnement[]
  conversationsClient Conversation[] @relation("ConversationsClient")
  messagesEnvoyes     Message[]      @relation("MessagesEnvoyes")

  @@map("users")
}

model Abonnement {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack              PackPremium
  montant           Float // en FCFA
  statut            StatutAbonnement @default(EN_ATTENTE)
  moyenPaiement     MoyenPaiement?
  referencePaiement String? // ID de transaction mobile money fourni par le client
  debutLe           DateTime?
  finLe             DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId])
  @@index([statut])
  @@map("abonnements")
}

model Conversation {
  id            String      @id @default(cuid())
  clientId      String
  client        User        @relation("ConversationsClient", fields: [clientId], references: [id], onDelete: Cascade)
  prestataireId String
  prestataire   Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  messages      Message[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([clientId, prestataireId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessagesEnvoyes", fields: [senderId], references: [id], onDelete: Cascade)
  contenu        String
  lu             Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Indisponibilite {
  id            String      @id @default(cuid())
  prestataireId String
  prestataire   Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  date          DateTime
  motif         String?
  createdAt     DateTime    @default(now())

  @@unique([prestataireId, date])
  @@map("indisponibilites")
}

model Service {
  id            String      @id @default(cuid())
  prestataireId String
  prestataire   Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  nom           String
  description   String?
  prix          Float
  unite         String? // "forfait", "par personne", "par heure", "par jour"
  actif         Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([prestataireId, actif])
  @@map("services")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model Categorie {
  id           String        @id @default(cuid())
  nom          String        @unique
  slug         String        @unique
  description  String?
  icone        String?
  couleur      String?
  createdAt    DateTime      @default(now())
  prestataires Prestataire[]

  @@map("categories")
}

model Tag {
  id           String        @id @default(cuid())
  nom          String
  slug         String        @unique
  groupe       String
  icone        String?
  createdAt    DateTime      @default(now())
  prestataires Prestataire[] @relation("PrestataireTags")

  @@map("tags")
}

model Prestataire {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  categorieId   String
  categorie     Categorie     @relation(fields: [categorieId], references: [id])
  nomEntreprise String
  description   String?
  quartier      String
  commune       String?
  ville         String        @default("Abidjan")
  latitude      Float?
  longitude     Float?
  telephone     String?
  whatsapp      String?
  email         String?
  siteWeb       String?
  photos        String[]
  prixMin       Float?
  prixMax       Float?
  notemoyenne   Float         @default(0)
  totalAvis     Int           @default(0)
  verifie       Boolean       @default(false)
  actif         Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  reservations  Reservation[]
  avis          Avis[]
  tags          Tag[]         @relation("PrestataireTags")
  favoris       Favori[]
  conversations Conversation[]
  indisponibilites Indisponibilite[]
  services      Service[]

  @@index([ville, commune])
  @@index([latitude, longitude])
  @@index([categorieId])
  @@map("prestataires")
}

model Reservation {
  id              String            @id @default(cuid())
  clientId        String
  client          User              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  prestataireId   String
  prestataire     Prestataire       @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  dateEvenement   DateTime
  lieuEvenement   String
  typeEvenement   String
  nombrePersonnes Int?
  message         String?
  budget          Float?
  statut          StatutReservation @default(EN_ATTENTE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  avis            Avis?

  @@map("reservations")
}

model Avis {
  id            String       @id @default(cuid())
  auteurId      String
  auteur        User         @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  prestataireId String
  prestataire   Prestataire  @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  reservationId String?      @unique
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  note          Int
  commentaire   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("avis")
}

model Favori {
  id            String      @id @default(cuid())
  clientId      String
  client        User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  prestataireId String
  prestataire   Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([clientId, prestataireId])
  @@map("favoris")
}

model Parametre {
  id        String   @id @default(cuid())
  cle       String   @unique
  valeur    Json
  updatedAt DateTime @updatedAt

  @@map("parametres")
}
